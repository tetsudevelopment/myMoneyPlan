# Credenciales de Supabase
# Copia este archivo como .env y rellena con tus valores reales.
# El .env real NUNCA se sube a git (está en .gitignore).

# Tu Project URL (sin /rest/v1/ al final), ej: https://xxxxx.supabase.co
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Tu Publishable / anon key (sb_publishable_...) — segura para el frontend con RLS activo.
# NUNCA pongas aquí la secret key.
VITE_SUPABASE_ANON_KEY=sb_publishable_TU_LLAVE_AQUI
